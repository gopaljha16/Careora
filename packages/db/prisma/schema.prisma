generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  name               String
  passwordHash       String
  emailNotifications Boolean       @default(true)
  reminderEnabled    Boolean       @default(true)
  reminderTime       String        @default("09:00")
  dailyGoal          Int           @default(5)
  lastReminderSentAt DateTime?
  createdAt          DateTime      @default(now())
  jobs               Job[]
  applications       Application[]
  dailyReferralLogs  DailyReferralLog[]
  learningEntries    LearningEntry[]
}

model Job {
  id           String        @id @default(cuid())
  userId       String
  company      String
  role         String
  jobUrl       String?
  location     String?
  salary       String?
  description  String?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id         String            @id @default(cuid())
  jobId      String
  userId     String
  status     ApplicationStatus @default(WISHLIST)
  appliedAt    DateTime?
  updatedAt    DateTime          @updatedAt
  source       String?
  notes        String?
  platform     String?
  isReferral   Boolean           @default(false)
  referralName String?
  resumeVersion    String?
  coverLetterNotes String?
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  appNotes   ApplicationNote[]
  interviews InterviewRound[]

  @@index([userId])
  @@index([userId, status])
  @@index([jobId])
}

model ApplicationNote {
  id            String      @id @default(cuid())
  applicationId String
  content       String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

enum RoundType {
  PHONE
  TECHNICAL
  BEHAVIORAL
  FINAL
}

model InterviewRound {
  id            String      @id @default(cuid())
  applicationId String
  roundType     RoundType
  scheduledAt   DateTime
  outcome       String?
  notes         String?
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model DailyReferralLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  platform  String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, platform])
  @@index([userId])
}

model LearningEntry {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  content         String
  missed          String?
  dayRating       Int?
  wakeUpTime      String?
  sleepTime       String?
  instaScreenTime Int?
  daySummary      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

